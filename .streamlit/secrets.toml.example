# 复制为本地 secrets（勿提交 Git）：
#   cp .streamlit/secrets.toml.example .streamlit/secrets.toml
#
# Streamlit Cloud：在应用 Settings → Secrets 粘贴 TOML 内容。
#
# 当前版本使用 Binance 公开行情，无密钥也可运行。
# 若日后接入需鉴权的 API，可在此添加，例如：

# [binance]
# api_key = "your-key"
# api_secret = "your-secret"

# [okx]
# api_key = ""
# api_secret = ""
# passphrase = ""
